#!/bin/sh
# gobot pre-commit hook
# Runs go vet and the full test suite before every commit.
# A non-zero exit from either command aborts the commit.
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

cd "$(git rev-parse --show-toplevel)"

TEMP_LOG=$(mktemp)

cleanup() {
    rm -f "$TEMP_LOG"
}
trap cleanup EXIT

echo "--- Pre-commit verification started"

# Check vendor consistency whenever go.mod or go.sum are staged.
if git diff --cached --name-only | grep -qE '^(go\.mod|go\.sum)$'; then
    echo "--- go mod vendor (consistency check)"
    go mod vendor
    if ! git diff --exit-code vendor/ > "$TEMP_LOG" 2>&1; then
        echo "ERROR: vendor/ is out of sync with go.mod. Stage the updated vendor/ directory."
        cat "$TEMP_LOG"
        exit 1
    fi
fi

if ! go vet -mod=readonly ./... > "$TEMP_LOG" 2>&1; then
    echo "ERROR: go vet failed"
    cat "$TEMP_LOG"
    exit 1
fi

if ! staticcheck ./... > "$TEMP_LOG" 2>&1; then
    echo "ERROR: staticcheck failed"
    cat "$TEMP_LOG"
    exit 1
fi

if ! go test -mod=readonly ./... > "$TEMP_LOG" 2>&1; then
    echo "ERROR: go test failed"
    cat "$TEMP_LOG"
    exit 1
fi

echo "--- Pre-commit: all checks passed (vendor, vet, staticcheck, test)"
