#!/bin/sh
# gobot pre-commit hook
# Runs golangci-lint and go mod verify before every commit.
# A non-zero exit from any command aborts the commit.
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

cd "$(git rev-parse --show-toplevel)"

# Isolate Go and Lint caches per worktree to prevent lock contention
export GOCACHE="$(git rev-parse --show-toplevel)/.go-build-cache"
export GOLANGCI_LINT_CACHE="$(git rev-parse --show-toplevel)/.golangci-lint-cache"

# 0. Block accidental .private/ leakage
PRIVATE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(.private/|.gemini/|.agent-workspaces/)' || true)
if [ -n "$PRIVATE_FILES" ]; then
    echo "CRITICAL ERROR: Attempting to commit private files in restricted directories (.private/, .gemini/, or .agent-workspaces/)"
    echo "These directories are for local Dev Factory use only and must NEVER be committed."
    echo "Offending files:"
    echo "$PRIVATE_FILES"
    echo "Please run: git rm --cached -r <dir>"
    exit 1
fi

TEMP_LOG=$(mktemp)

cleanup() {
    rm -f "$TEMP_LOG"
}
trap cleanup EXIT

echo "--- Pre-commit verification started"

# 1. Block hardcoded absolute drive paths (e.g. system drives)
# We exclude vendor/ and only check added lines (+) in staged files.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^vendor/' || true)
if [ -n "$STAGED_FILES" ]; then
    # We check only added lines (starting with +) but skip the +++ file header.
    # Matches common absolute drive patterns like C:\ or D:\
    # We check for a drive letter followed by a colon and a backslash.
    if git diff --cached --unified=0 -- "$STAGED_FILES" | grep '^\+' | grep -v '^\+\+\+' | grep -Ei '[A-Z]:\\\\+' > /dev/null 2>&1; then
        echo "ERROR: Hardcoded absolute drive paths detected in added lines."
        echo "Please remove these personal environment paths before committing."
        echo "Offending lines:"
        git diff --cached --unified=0 -- "$STAGED_FILES" | grep '^\+' | grep -v '^\+\+\+' | grep -Ei '[A-Z]:\\\\+'
        exit 1
    fi
fi

if ! go mod verify > "$TEMP_LOG" 2>&1; then
    echo "ERROR: go mod verify failed (go.sum integrity check)"
    cat "$TEMP_LOG"
    exit 1
fi

# golangci-lint must match the version pinned in .github/workflows/ci.yml.
# Install: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4
REQUIRED_LINT_VERSION="v2.11.4"
if command -v golangci-lint > /dev/null 2>&1; then
    INSTALLED_LINT_VERSION=$(golangci-lint version --short 2>/dev/null || echo "unknown")
    # Prefix with 'v' if missing to match REQUIRED_LINT_VERSION
    case "$INSTALLED_LINT_VERSION" in
        v*) ;;
        unknown) ;;
        *) INSTALLED_LINT_VERSION="v$INSTALLED_LINT_VERSION" ;;
    esac

    if [ "$INSTALLED_LINT_VERSION" != "$REQUIRED_LINT_VERSION" ]; then
        echo "ERROR: golangci-lint version mismatch."
        echo "  Installed: $INSTALLED_LINT_VERSION"
        echo "  Required:  $REQUIRED_LINT_VERSION (matches CI)"
        echo "  Fix: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@$REQUIRED_LINT_VERSION"
        exit 1
    fi
    if ! golangci-lint config verify > "$TEMP_LOG" 2>&1; then
        echo "ERROR: golangci-lint config verify failed (schema mismatch — fix .golangci.yml before committing)"
        cat "$TEMP_LOG"
        exit 1
    fi
    if ! golangci-lint run --modules-download-mode=readonly > "$TEMP_LOG" 2>&1; then
        echo "ERROR: golangci-lint failed"
        cat "$TEMP_LOG"
        exit 1
    fi
    # On Windows the default GOOS skips files tagged //go:build !windows.
    # Run a second pass targeting Linux so platform-specific code is also linted.
    if [ "$(go env GOOS)" = "windows" ] && git diff --cached --name-only | grep -qE '(_unix|_linux|_darwin)\.go$'; then
        if ! GOOS=linux golangci-lint run --modules-download-mode=readonly > "$TEMP_LOG" 2>&1; then
            echo "ERROR: golangci-lint (GOOS=linux) failed on unix-tagged files"
            cat "$TEMP_LOG"
            exit 1
        fi
    fi
else
    echo "WARN: golangci-lint not found locally; CI will enforce lint"
fi

# Dev factory quality gate — mandatory when factory is present
if [ -f ".private/scripts/factory_lint.go" ]; then
    if ! go run .private/scripts/factory_lint.go > "$TEMP_LOG" 2>&1; then
        echo "ERROR: factory lint failed"
        cat "$TEMP_LOG"
        exit 1
    fi
fi

echo "--- Pre-commit: all checks passed (lint)"
