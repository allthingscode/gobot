#!/bin/sh
# gobot pre-push hook
# Mirrors the CI vendor-check job — catches vendor drift before it reaches GitHub.
# A non-zero exit aborts the push.
#
# Install: cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

cd "$(git rev-parse --show-toplevel)"

echo "--- pre-push: verifying vendor consistency"
go mod vendor
if ! git diff --exit-code vendor/; then
    echo ""
    echo "ERROR: vendor/ is out of sync with go.mod/go.sum."
    echo "       Stage and commit the updated vendor/ directory, then push again."
    exit 1
fi

echo "--- pre-push: running security scan"
if command -v powershell.exe > /dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/check_security.ps1
else
    # Fallback for Linux/macOS if govulncheck is installed
    if command -v govulncheck > /dev/null 2>&1; then
        govulncheck ./...
    else
        echo "WARN: govulncheck not found; skipping local security scan (CI will enforce)"
    fi
fi

echo "--- pre-push: checking CI status on remote branch"
if command -v gh > /dev/null 2>&1; then
    # Determine the branch being pushed to
    TARGET_BRANCH=$(git for-each-ref --format='%(upstream:short)' "$(git symbolic-ref HEAD 2>/dev/null)" 2>/dev/null | sed 's|.*/||')
    if [ -z "$TARGET_BRANCH" ]; then
        TARGET_BRANCH="master"
    fi
    LAST_RUN=$(gh run list --branch="$TARGET_BRANCH" --limit 1 --json conclusion,status,url 2>/dev/null || echo "")
    if [ -n "$LAST_RUN" ] && [ "$LAST_RUN" != "[]" ]; then
        CONCLUSION=$(echo "$LAST_RUN" | grep -o '"conclusion":"[^"]*"' | head -1 | sed 's/"conclusion":"//;s/"//')
        STATUS=$(echo "$LAST_RUN" | grep -o '"status":"[^"]*"' | head -1 | sed 's/"status":"//;s/"//')
        RUN_URL=$(echo "$LAST_RUN" | grep -o '"url":"[^"]*"' | head -1 | sed 's/"url":"//;s/"//')
        if [ "$STATUS" = "in_progress" ] || [ "$STATUS" = "queued" ]; then
            echo "    CI is running on $TARGET_BRANCH — push proceeds."
        elif [ "$CONCLUSION" = "success" ]; then
            echo "    CI is GREEN on $TARGET_BRANCH — push proceeds."
        elif [ "$CONCLUSION" = "failure" ]; then
            echo ""
            echo "WARNING: CI is FAILING on $TARGET_BRANCH — last run: $RUN_URL"
            echo "         Push proceeds only if this commit is the fix."
            echo ""
        fi
    else
        echo "    (no recent CI runs found for $TARGET_BRANCH)"
    fi
else
    echo "    WARN: gh not found; skipping CI status check"
fi

echo "--- pre-push: running tests"
TEMP_LOG=$(mktemp)
cleanup() { rm -f "$TEMP_LOG"; }
trap cleanup EXIT
# Run tests with the race detector when a C compiler is available; fall back
# gracefully when CGO is absent (e.g. bare Windows without WSL).
if ! go test -race -mod=readonly ./... > "$TEMP_LOG" 2>&1; then
    if grep -q "requires cgo\|requires a C compiler" "$TEMP_LOG"; then
        echo "WARN: Race detector unavailable (no C compiler — CGO disabled)."
        echo "      Run 'wsl -e go test -race -mod=readonly ./...' to catch data races."
        if ! go test -mod=readonly ./... > "$TEMP_LOG" 2>&1; then
            echo "ERROR: go test failed"
            cat "$TEMP_LOG"
            exit 1
        fi
    else
        echo "ERROR: go test -race failed"
        cat "$TEMP_LOG"
        exit 1
    fi
fi

# Cross-compile for Linux to catch platform-incompatible code before CI does.
# On Linux/macOS this is a no-op (native GOOS already covers it).
if [ "$(go env GOOS)" = "windows" ]; then
    echo "--- pre-push: GOOS=linux compile check"
    if ! GOOS=linux go test -run=^$ -exec=echo -mod=readonly ./... > "$TEMP_LOG" 2>&1; then
        echo "ERROR: GOOS=linux compile check failed — code will not build on CI"
        cat "$TEMP_LOG"
        exit 1
    fi
fi

echo "--- pre-push: checking for unguarded platform-specific commands"
if ! ./scripts/check_platform_cmds.sh; then
    exit 1
fi

echo "--- pre-push: validating config.json"
# We check the default config path (~/.gobot/config.json)
if ! go run ./cmd/gobot config reformat --check > /dev/null 2>&1; then
    echo "ERROR: config.json is not correctly formatted."
    echo "       Run 'go run ./cmd/gobot config reformat' to fix."
    exit 1
fi
if ! go run ./cmd/gobot config validate > /dev/null 2>&1; then
    echo "ERROR: config.json validation failed."
    echo "       Run 'go run ./cmd/gobot config validate' for details."
    exit 1
fi

echo "--- pre-push: all checks passed"
