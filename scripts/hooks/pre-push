#!/bin/sh
# gobot pre-push hook
# Mirrors the CI vendor-check job — catches vendor drift before it reaches GitHub.
# A non-zero exit aborts the push.
#
# Install: cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

cd "$(git rev-parse --show-toplevel)"

echo "--- pre-push: verifying vendor consistency"
go mod vendor
if ! git diff --exit-code vendor/; then
    echo ""
    echo "ERROR: vendor/ is out of sync with go.mod/go.sum."
    echo "       Stage and commit the updated vendor/ directory, then push again."
    exit 1
fi

echo "--- pre-push: running security scan"
if command -v powershell.exe > /dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/check_security.ps1
else
    # Fallback for Linux/macOS if govulncheck is installed
    if command -v govulncheck > /dev/null 2>&1; then
        govulncheck ./...
    else
        echo "WARN: govulncheck not found; skipping local security scan (CI will enforce)"
    fi
fi

echo "--- pre-push: all checks passed"
